<?xml version="1.0" encoding="utf-8"?>
<package >
  <metadata>
    <id>Imgui.Forms</id>
    <version>2.1.3</version>
    <description>A WinForms-inspired object-oriented framework around Dear ImGui (https://github.com/ocornut/imgui)</description>

    <authors>onepiecefreak</authors>
    <owners>onepiecefreak</owners>
    <copyright>Copyright (c) 2021-2026 onepiecefreak</copyright>

    <projectUrl>https://github.com/FanTranslatorsInternational/ImGui.Forms</projectUrl>
    <tags>ImGui;Forms;ImGui.NET;GUI</tags>

    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>

    <repository type="git" url="https://github.com/FanTranslatorsInternational/ImGui.Forms" />

    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="SixLabors.ImageSharp" version="3.1.12" />
        <dependency id="Hexa.NET.ImGui" version="2.2.9" />
        <dependency id="Hexa.NET.ImGui.Backends" version="1.0.18" />
        <dependency id="Hexa.NET.ImGui.Backends.SDL3" version="1.0.18" />
        <dependency id="Hexa.NET.ImGuizmo" version="2.2.9" />
        <dependency id="Hexa.NET.SDL3" version="1.2.17" />
      </group>
    </dependencies>
  </metadata>

  <files>
    <file src="bin\Release\net8.0\*.dll" target="lib\net8.0\"/>
  </files>
</package>
